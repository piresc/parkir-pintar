# =============================================================================
# Environment & Secrets
# =============================================================================
# Ignore actual .env files that may contain real secrets.
# .env.example and config/.env.example are kept as templates.
.env
config/.env
!config/.env.example
!.env.example

# =============================================================================
# Go Build Artifacts
# =============================================================================
# Compiled binaries (must match service names in cmd/)
/api
/gateway
/reservation
/search
/billing
/payment
/presence
/notification

# Generic patterns
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# =============================================================================
