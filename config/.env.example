# =============================================================================
# Parkir Pintar — Environment Variables (Secrets Only)
# =============================================================================
# Copy this file to config/.env and fill in your values.
# In local mode (APP_ENV=local), the .env file is loaded automatically.
#
# All non-secret configuration lives in config/<service>.<env>.yaml files.
# This file should contain ONLY secrets and credentials.
# No real secrets should be committed — use placeholder values only.
# =============================================================================

# -----------------------------------------------------------------------------
# Database Credentials
# -----------------------------------------------------------------------------
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=your_redis_password

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars-long
