# =============================================================================
# Assessment Boilerplate — Environment Variables
# =============================================================================
# Copy this file to config/.env and fill in your values.
# In local mode (APP_ENV=local), the .env file is loaded automatically.
# No real secrets should be committed — use placeholder values only.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=parkir-pintar
APP_ENV=local
APP_DEBUG=false
APP_VERSION=0.0.1

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15
SERVER_WRITE_TIMEOUT=15
SERVER_SHUTDOWN_TIMEOUT=30
SERVER_ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name
DB_SSL_MODE=disable
DB_MAX_CONNS=25
DB_IDLE_CONNS=5
DB_MAX_LIFETIME=15

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_POOL_SIZE=10

# -----------------------------------------------------------------------------
# NATS
# -----------------------------------------------------------------------------
NATS_URL=nats://localhost:4222

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=60
JWT_ISSUER=parkir-pintar

# -----------------------------------------------------------------------------
# Auth (API Keys)
# Comma-separated "service:key" pairs, e.g. svc1:key1,svc2:key2
# -----------------------------------------------------------------------------
AUTH_API_KEYS=service1:your_api_key_1,service2:your_api_key_2

# -----------------------------------------------------------------------------
# Tracing (OpenTelemetry)
# Exporter options: stdout, otlp, newrelic, noop
# -----------------------------------------------------------------------------
TRACING_ENABLED=false
TRACING_SERVICE_NAME=parkir-pintar
TRACING_SAMPLE_RATE=1.0
TRACING_EXCLUDE_PATHS=/health,/health/live,/health/ready
TRACING_EXPORTER=noop
TRACING_OTLP_ENDPOINT=http://localhost:4318

# -----------------------------------------------------------------------------
# New Relic (OTEL Exporter)
# Used only when TRACING_EXPORTER=newrelic
# -----------------------------------------------------------------------------
NEW_RELIC_LICENSE_KEY=your_newrelic_license_key
NEW_RELIC_ENABLED=false

# -----------------------------------------------------------------------------
# Logger
# Level options: debug, info, warn, error
# Format options: json, text
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# HTTP Client (pkg/httpclient)
# Used for outbound HTTP calls with retry, tracing, and stub support.
# -----------------------------------------------------------------------------
HTTPCLIENT_TIMEOUT=30s
HTTPCLIENT_BASE_URL=https://api.example.com
HTTPCLIENT_API_KEY=your_httpclient_api_key

# Stub support — for non-production environments only.
# When enabled, the StubRoundTripper returns canned responses instead of
# making real HTTP calls.
HTTPCLIENT_STUB_ENABLED=false

# Global stub response (JSON string returned for ALL requests when stubbing is on)
HTTPCLIENT_STUB_GLOBAL_RESPONSE={"status":"stubbed","data":{}}

# Per-MSISDN stub responses (JSON map: msisdn → response body)
# Example: {"628123456789":{"status":"ok"},"628987654321":{"status":"blocked"}}
HTTPCLIENT_STUB_MSISDN_RESPONSES={}
