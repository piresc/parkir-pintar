{
  "project": "ParkirPintar",
  "description": "Smart Parking Reservation System — Microservices Architecture",
  "version": "1.0.0",
  "tech_stack": {
    "language": "Go 1.23",
    "framework": "Gin (HTTP), gRPC (inter-service)",
    "database": "PostgreSQL 14",
    "cache": "Redis 7.0",
    "messaging": "NATS 2.10 (JetStream)",
    "task_queue": "Asynq (Redis-backed)",
    "observability": "OpenTelemetry → Alloy → Prometheus/Tempo/Loki",
    "ci_cd": "GitHub Actions → GHCR → Watchtower",
    "deployment": "Docker Compose (Coolify-managed host)"
  },
  "services": {
    "gateway": {
      "type": "api_gateway",
      "port": 8082,
      "internal_port": 8080,
      "protocol": "HTTP/REST",
      "framework": "Gin",
      "role": "REST API gateway. Transcodes HTTP→gRPC to downstream services. Serves analytics and billing endpoints directly.",
      "dependencies": ["reservation", "search", "billing", "payment", "postgres", "redis"],
      "routes": {
        "reservations": [
          "POST /api/v1/reservations",
          "GET /api/v1/reservations?driver_id=&status=",
          "GET /api/v1/reservations/:id",
          "DELETE /api/v1/reservations/:id",
          "POST /api/v1/reservations/:id/checkin",
          "POST /api/v1/reservations/:id/checkout",
          "POST /api/v1/reservations/:id/confirm",
          "POST /api/v1/reservations/:id/complete",
          "GET /api/v1/reservations/:id/billing"
        ],
        "search": [
          "GET /api/v1/availability?vehicle_type=",
          "GET /api/v1/floors/:floor",
          "GET /api/v1/spots/:id"
        ],
        "payments": [
          "GET /api/v1/payments/:id/status"
        ],
        "analytics": [
          "GET /api/v1/analytics/peak-hours",
          "GET /api/v1/analytics/occupancy"
        ],
        "docs": [
          "/swagger",
          "/swagger/doc.yaml"
        ]
      },
      "middleware": ["recovery", "cors", "rate_limiting", "jwt_auth", "tracing", "security_headers", "metrics"]
    },
    "reservation": {
      "type": "domain_service",
      "port": 9091,
      "protocol": "gRPC",
      "role": "Core domain service. Manages reservation lifecycle. Orchestrates billing + payment via gRPC. Publishes events to NATS. Uses Redis for distributed locking and Asynq for delayed tasks.",
      "dependencies": ["billing", "payment", "postgres", "redis", "nats"],
      "grpc_methods": [
        "CreateReservation",
        "GetReservation",
        "CancelReservation",
        "CheckIn",
        "CheckOut",
        "ConfirmReservation",
        "CompleteCheckout",
        "ExpireReservation",
        "ListByDriver"
      ],
      "publishes": [
        "reservation.search.spot-updated",
        "reservation.analytics.created",
        "reservation.analytics.confirmed",
        "reservation.analytics.checked-in",
        "reservation.analytics.completed",
        "reservation.analytics.cancelled",
        "reservation.analytics.expired",
        "reservation.analytics.failed"
      ],
      "subscribes": [
        "payment.reservation.success",
        "payment.reservation.failed"
      ],
      "async_tasks": [
        "task:reservation:expire",
        "task:payment:hold_timeout"
      ],
      "db_schema": "reservation",
      "tables": ["drivers", "parking_spots", "reservations"]
    },
    "search": {
      "type": "domain_service",
      "port": 9092,
      "protocol": "gRPC",
      "role": "Read-model service (CQRS). Provides real-time parking availability and floor maps. Maintains spot_read_model synced via NATS events.",
      "dependencies": ["postgres", "redis", "nats"],
      "grpc_methods": [
        "GetAvailability",
        "GetFloorMap",
        "GetSpotDetails"
      ],
      "subscribes": [
        "reservation.search.spot-updated"
      ],
      "publishes": [],
      "db_schema": "search",
      "tables": ["spot_read_model"]
    },
    "billing": {
      "type": "domain_service",
      "port": 9093,
      "protocol": "gRPC",
      "role": "Fee calculation, invoice generation. Stateless compute over billing_records.",
      "dependencies": ["postgres"],
      "grpc_methods": [
        "StartBilling",
        "CalculateFee",
        "GenerateInvoice",
        "ApplyPenalty",
        "ApplyOvernightFee"
      ],
      "publishes": [],
      "subscribes": [],
      "db_schema": "billing",
      "tables": ["billing_records", "penalties"]
    },
    "payment": {
      "type": "domain_service",
      "port": 9094,
      "protocol": "gRPC",
      "role": "Payment processing (QRIS, credit card, debit, e-wallet). Publishes payment results to NATS.",
      "dependencies": ["postgres", "nats"],
      "grpc_methods": [
        "ProcessPayment",
        "ProcessQRIS",
        "RefundPayment",
        "GetPaymentStatus"
      ],
      "publishes": [
        "payment.reservation.success",
        "payment.reservation.failed"
      ],
      "subscribes": [],
      "db_schema": "payment",
      "tables": ["payments"]
    }
  },
  "infrastructure": {
    "postgres": {
      "type": "database",
      "image": "postgres:14-alpine",
      "port": 5432,
      "schemas": ["reservation", "billing", "payment", "search"],
      "seed_data": "400 spots (5 floors × 30 car + 50 motorcycle per floor)"
    },
    "redis": {
      "type": "cache",
      "image": "redis:7.0-alpine",
      "port": 6379,
      "uses": ["caching", "distributed_locks", "rate_limiting", "idempotency", "asynq_task_queue"]
    },
    "nats": {
      "type": "message_bus",
      "image": "nats:2.10-alpine",
      "port": 4222,
      "monitoring_port": 8222,
      "jetstream": true,
      "streams": {
        "RESERVATION_SEARCH": {
          "subjects": ["reservation.search.*"],
          "retention": "InterestPolicy",
          "max_age": "24h",
          "purpose": "Spot status updates → Search service"
        },
        "RESERVATION_ANALYTICS": {
          "subjects": ["reservation.analytics.*"],
          "retention": "LimitsPolicy",
          "max_age": "7d",
          "purpose": "Reservation lifecycle events → Analytics"
        },
        "PAYMENT_RESERVATION": {
          "subjects": ["payment.reservation.*"],
          "retention": "InterestPolicy",
          "max_age": "24h",
          "purpose": "Payment results → Reservation service"
        }
      },
      "consumers": {
        "search-spot-consumer": {
          "stream": "RESERVATION_SEARCH",
          "service": "search"
        },
        "analytics-consumer": {
          "stream": "RESERVATION_ANALYTICS",
          "service": "analytics"
        },
        "reservation-payment-consumer": {
          "stream": "PAYMENT_RESERVATION",
          "service": "reservation"
        }
      }
    }
  },
  "monitoring": {
    "access": "Tailscale only (100.79.123.39)",
    "components": {
      "prometheus": {
        "port": 9090,
        "retention": "30d",
        "scrape_targets": ["gateway", "search", "reservation", "billing", "payment", "postgres-exporter", "redis-exporter", "nats-exporter"]
      },
      "grafana": {
        "port": 3000,
        "dashboards": ["executive", "infrastructure", "microservices"],
        "datasources": ["prometheus", "tempo", "loki"]
      },
      "tempo": {
        "port": 3200,
        "otlp_grpc": 4317,
        "otlp_http": 4318,
        "role": "Distributed tracing"
      },
      "loki": {
        "port": 3100,
        "retention": "7d",
        "role": "Log aggregation"
      },
      "alloy": {
        "port_ui": 12345,
        "port_otlp": 4319,
        "role": "Unified telemetry collector (traces → Tempo, metrics → Prometheus, logs → Loki)"
      },
      "alertmanager": {
        "port": 9093,
        "role": "Alert routing"
      }
    },
    "exporters": {
      "postgres-exporter": { "port": 9187 },
      "redis-exporter": { "port": 9121 },
      "nats-exporter": { "port": 7777 }
    }
  },
  "ci_cd": {
    "platform": "GitHub Actions",
    "registry": "ghcr.io/piresc/parkir-pintar",
    "pipeline": {
      "ci": {
        "trigger": "push to main & PRs",
        "steps": [
          "secret-scan (gitleaks)",
          "lint (golangci-lint v2.12.2)",
          "test (race detector + coverage + benchmarks)",
          "security (gosec → sonarqube format)",
          "vulncheck (govulncheck)",
          "proto-check (buf lint + breaking change detection)",
          "build-push-staging (GHCR: main-<sha>, latest)",
          "dast (OWASP ZAP baseline scan)",
          "sonar (SonarCloud analysis)"
        ]
      },
      "cd": {
        "trigger": "version tags v*.*.*",
        "steps": ["test", "build-and-push (semver + sha)", "deploy-staging"]
      },
      "load_test": {
        "trigger": "manual + weekly (Sunday 2am UTC)",
        "tool": "k6 smoke test"
      }
    },
    "deployment_mechanism": "Watchtower polls GHCR every 60s for :latest tag"
  },
  "shared_packages": {
    "pkg/config": "Centralized env-based config loading",
    "pkg/nats": "NATS JetStream client, publisher, stream/consumer creation",
    "pkg/redis": "Redis client wrapper with tracing",
    "pkg/redislock": "Distributed locking via Redis (12min TTL)",
    "pkg/middleware": "HTTP middleware (auth, CORS, rate limiting, recovery, tracing, security headers)",
    "pkg/grpcmiddleware": "gRPC interceptors (auth, recovery, tracing, rate limiting, logging, idempotency)",
    "pkg/health": "Health check endpoints (liveness/readiness)",
    "pkg/pricing": "Fee calculation engine (booking 5K, hourly 5K, overnight 20K)",
    "pkg/metrics": "Prometheus metrics (HTTP + gRPC)",
    "pkg/asynq": "Redis-based async task queue",
    "pkg/database": "PostgreSQL connection pool with tracing",
    "pkg/auth": "JWT token generation/validation",
    "pkg/grpcclient": "gRPC client factory",
    "pkg/grpcserver": "gRPC server bootstrap",
    "pkg/server": "HTTP server bootstrap (Gin)",
    "pkg/tracing": "OpenTelemetry tracer setup",
    "pkg/circuitbreaker": "Circuit breaker pattern",
    "pkg/logger": "Structured slog logger",
    "pkg/apperror": "Application error types with codes",
    "pkg/response": "Standardized HTTP response helpers"
  },
  "reservation_states": {
    "flow": "waiting_payment → confirmed → checked_in → checked_out → completed",
    "terminal_states": ["completed", "cancelled", "expired", "failed"],
    "transitions": {
      "waiting_payment": ["confirmed", "cancelled", "expired"],
      "confirmed": ["checked_in", "cancelled"],
      "checked_in": ["checked_out"],
      "checked_out": ["completed", "failed"]
    }
  },
  "pricing": {
    "booking_fee": 5000,
    "hourly_rate": 5000,
    "overnight_fee": 20000,
    "currency": "IDR",
    "payment_methods": ["qris", "credit_card", "debit", "ewallet"]
  }
}
